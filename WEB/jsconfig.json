{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"],
      "app/*": ["*"],
      "components/*": ["src/components/*"],
      "layouts/*": ["src/layouts/*"],
      "pages/*": ["src/pages/*"],
      "assets/*": ["src/assets/*"],
      "boot/*": ["src/boot/*"],
      "stores/*": ["src/stores/*"],
      "composables/*": ["src/composables/*"],
      "shared/*": ["src/shared/*"],
      "services/*": ["src/services/*"],
      "validators/*": ["src/validators/*"],
      "modules/*": ["src/modules/*"],
      "dialogs/*": ["src/dialogs/*"]
    }
  },
  "exclude": ["dist", ".quasar", "node_modules"]
}
